# Port (optional, default 3000)
PORT=3000

# --- Optional: made-to-order consultation (conversations / proposals) ---
# When true, creates consultation_* tables usage and exposes /api/consultation/* (isolated from legacy purchase flow).
# ENABLE_CONSULTATION_FLOW=true
# Frontend: optional hard-off even if server enables API — VITE_ENABLE_CONSULTATION_FLOW=false
# Optional: send SMTP emails to clients on consultation events (requires mail configured). Default off.
# CONSULTATION_EMAIL_NOTIFICATIONS=true

# --- Session-Sicherheit (Produktion PFLICHT, min. 32 Zeichen) ---
# Signiert das session-Cookie — ohne Secret kann jeder session=<beliebigeUserId> fälschen.
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=

# Öffentliche App-URL (https in Produktion — aktiviert Secure-Cookies)
# APP_URL=https://vault.example.com

# Datenbank (optional, default vault.db)
# DATABASE_PATH=vault.db

# Neue Nutzer-IDs beginnen mindestens hier (Standard 247; Gast hat keine DB-Zeile, session id=0).
# MIN_USER_ID=247

# --- Google Cloud SQL (PostgreSQL) ---
# Test: node scripts/test-cloud-sql.js
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# PGHOST=... PGPORT=5432 PGUSER=... PGPASSWORD=... PGDATABASE=vault

# --- Google Cloud SQL (MySQL) – z.B. bellanova-main-db / bellanova_vault ---
# Test: node scripts/test-cloud-sql-mysql.js
# MYSQL_HOST=ÖFFENTLICHE_IP_DER_INSTANZ
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=...
# MYSQL_DATABASE=bellanova_vault
# Oder eine URL: DATABASE_URL=mysql://root:PASSWORT@IP:3306/bellanova_vault

# --- E-Mail (Kontaktformular "Nachricht senden") ---
# Wenn gesetzt, wird beim Absenden eine E-Mail an ADMIN_EMAIL geschickt.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@bellanova.com
# E-Mail-Adresse, an die Kontaktanfragen gesendet werden
ADMIN_EMAIL=antonio.bellanova@antoniobellanova.com

# --- Stripe (wallet deposits, invoice payments, direct purchases) ---
# WICHTIG: Echte Keys NUR in .env (lokal + auf dem Server), NIEMIT in .env.example einchecken.
# Diese Datei ist nur Vorlage. Die App lädt ausschließlich die Datei ".env" aus dem Projektordner.
#
# Dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...   (oder sk_live_...)
# STRIPE_PUBLISHABLE_KEY=pk_test_...   (oder STRIPE_PUBLIC_KEY=... — beide Namen werden unterstützt)
# STRIPE_WEBHOOK_SECRET=whsec_...   (von https://dashboard.stripe.com/webhooks )
# Webhook-URL: https://Ihr-Domainname/api/stripe/webhook — Event: payment_intent.succeeded
# Ohne Webhook bleibt das Wallet oft bei 0 € bis zur Rückkehr: Die App ruft nach dem Redirect optional
# POST /api/wallet/confirm-deposit auf (gleiche Gutschrift wie der Webhook, idempotent).
#
# Wallet / Auktionen: Ohne STRIPE_SECRET_KEY + STRIPE_PUBLISHABLE_KEY (oder STRIPE_PUBLIC_KEY) können Kunden kein Guthaben aufladen.
#
# Auf dem Server nach dem Eintragen in /opt/antonio-bellanova-vault/.env :
#   npm run build && pm2 restart vault --update-env
#
# Test mode: use sk_test_ / pk_test_ keys. Test card: 4242 4242 4242 4242 (any future expiry, any CVC).
